<UserControl x:Class="AtlasForge.Views.Controls.AtlasPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource BgDark}" CornerRadius="5" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AtlasTabBtn"
                                    Content="🖼 Atlas"
                                    Style="{StaticResource TabActiveStyle}"
                                    Click="AtlasTab_Click" />
                            <Button x:Name="AnimTabBtn"
                                    Content="▶ 動畫"
                                    Style="{StaticResource TabInactiveStyle}"
                                    Click="AnimTab_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="－"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="ZoomOut_Click"
                            Width="28" />
                    <TextBlock x:Name="ZoomLabel"
                               Text="100%"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10"
                               Margin="4,0"
                               VerticalAlignment="Center" />
                    <Button Content="＋"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="ZoomIn_Click"
                            Width="28" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.Background>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,16,16"
                                  ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#1A1A2E" Geometry="M0,0 H16 V16 H0Z" />
                                <GeometryDrawing Brush="#12121E" Geometry="M0,0 H8 V8 H0Z M8,8 H16 V16 H8Z" />
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>
                <Image x:Name="PreviewImage"
                       Stretch="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="16"
                       Source="{Binding AtlasPreview}"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#0F172A"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="10" />
        </Border>
    </Grid>
</UserControl>
