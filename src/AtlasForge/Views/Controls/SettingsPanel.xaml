<UserControl x:Class="AtlasForge.Views.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BgDark}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="排列模式" Style="{StaticResource SectionLabelStyle}" />
                        <Border Background="{StaticResource BgDark}" CornerRadius="5" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Grid"
                                             GroupName="PackMode"
                                             Margin="0,0,8,0"
                                             IsChecked="{Binding PackingMode, Converter={StaticResource IsGridMode}}"
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="10" />
                                <RadioButton Content="BinPack"
                                             GroupName="PackMode"
                                             IsChecked="{Binding PackingMode, Converter={StaticResource IsBinPackMode}}"
                                             Foreground="{StaticResource TextSecondary}"
                                             FontSize="10" />
                            </StackPanel>
                        </Border>
                        <CheckBox Content="自動計算行列"
                                  IsChecked="{Binding AutoGrid}"
                                  Margin="0,6,0,0" />
                        <Grid Margin="0,6,0,0"
                              IsEnabled="{Binding AutoGrid, Converter={StaticResource InverseBool}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="列 (可調整)"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="9"
                                           Margin="0,0,0,2" />
                                <TextBox Text="{Binding GridColumns, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingsInputStyle}"
                                         TextAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="行 (自動計算)"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="9"
                                           Margin="0,0,0,2" />
                                <TextBox Text="{Binding GridRows}"
                                         IsReadOnly="True"
                                         Style="{StaticResource SettingsInputStyle}"
                                         TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="幀處理" Style="{StaticResource SectionLabelStyle}" />
                        <CheckBox Content="Alpha Trim"
                                  IsChecked="{Binding AlphaTrim}"
                                  Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Padding (px)"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding Padding, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsInputStyle}"
                                     TextAlignment="Center" />
                        </Grid>
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Text="最大 Atlas 尺寸"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="9"
                                       Margin="0,0,0,2" />
                            <ComboBox SelectedValue="{Binding MaxAtlasSize}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="512 × 512" Tag="512" />
                                <ComboBoxItem Content="1024 × 1024" Tag="1024" />
                                <ComboBoxItem Content="2048 × 2048" Tag="2048" IsSelected="True" />
                                <ComboBoxItem Content="4096 × 4096" Tag="4096" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="輸出格式" Style="{StaticResource SectionLabelStyle}" />
                        <CheckBox Content="PNG 圖片"
                                  IsChecked="{Binding ExportPng}"
                                  Margin="0,0,0,4" />
                        <CheckBox IsChecked="{Binding ExportJson}" Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="JSON"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="10" />
                                <TextBlock Text="Unity 格式"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="9" />
                            </StackPanel>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding ExportPlist}">
                            <StackPanel>
                                <TextBlock Text="plist"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="10" />
                                <TextBlock Text="Cocos 格式"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="9" />
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <StackPanel Margin="10,10">
                    <Button Content="⬇ 匯出 Atlas"
                            Style="{StaticResource ExportButtonStyle}"
                            Command="{Binding ExportCommand}"
                            HorizontalAlignment="Stretch" />
                    <TextBlock Text="Ctrl+E"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="9"
                               TextAlignment="Center"
                               Margin="0,3,0,0" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
