<UserControl x:Class="AtlasForge.Views.Controls.FrameListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AtlasForge.ViewModels">

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <Grid>
                <TextBlock Text="幀列表"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="0"
                           VerticalAlignment="Center" />
                <TextBlock Text="⠿ 拖曳排序"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="9"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="8,6,8,0"
                Background="#14532D"
                BorderBrush="#16A34A"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8,2"
                Visibility="{Binding Frames.Count, Converter={StaticResource BoolToVis}}">
            <TextBlock Foreground="#4ADE80"
                       FontSize="10"
                       Text="{Binding Frames.Count, StringFormat='✓ {0} 幀已載入'}" />
        </Border>

        <Border Grid.Row="2"
                Margin="8,6,8,0"
                BorderBrush="{StaticResource BgLight}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="5"
                Background="{StaticResource BgMid}"
                AllowDrop="True"
                Drop="DropZone_Drop"
                DragOver="DropZone_DragOver">
            <TextBlock Text="拖放更多幀至此"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="10"
                       TextAlignment="Center" />
        </Border>

        <ListBox Grid.Row="3"
                 x:Name="FrameListBox"
                 ItemsSource="{Binding Frames}"
                 SelectedItem="{Binding SelectedFrame}"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="4"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="List_PreviewMouseMove"
                 Drop="List_Drop">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="4">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1D4ED8" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BgLight}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:FrameItemViewModel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0"
                               Source="{Binding Thumbnail}"
                               Width="24"
                               Height="24"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel Grid.Column="1"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="⠿"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Cursor="SizeAll" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="4"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button Content="↑↓ 排序"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Margin="0,0,4,0"
                        Click="SortButton_Click"
                        HorizontalAlignment="Stretch" />
                <Button Content="✕ 移除"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding RemoveSelectedFrameCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
